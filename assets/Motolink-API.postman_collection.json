{
  "info": {
    "name": "Motolink Backend API",
    "description": "moto-accessories-api — Spring Boot, session-cookie auth. Run folders top to bottom: Auth -> Categories -> Products -> Cart -> Wishlist -> Orders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Ali\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.test('Has user id and role', function () {",
                  "        pm.expect(json).to.have.property('id');",
                  "        pm.expect(json).to.have.property('role');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
          },
          "response": []
        },
        {
          "name": "Create Category (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.id) { pm.environment.set('categoryId', json.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Brakes\",\n  \"slug\": \"brakes\",\n  \"icon\": \"disc\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Category by Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Category (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Brakes & Rotors\",\n  \"slug\": \"brakes\",\n  \"icon\": \"disc\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Category (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "03 - Products",
      "item": [
        {
          "name": "Get All Products (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=20&sort=price,asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}", "disabled": true },
                { "key": "search", "value": "brake", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "price,asc" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Product (ADMIN, multipart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.id) { pm.environment.set('productId', json.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "product",
                  "value": "{\n  \"name\": \"Brake Pad Set\",\n  \"description\": \"High-performance ceramic pads\",\n  \"price\": 25.99,\n  \"brand\": \"Brembo\",\n  \"categoryId\": {{categoryId}},\n  \"stockQuantity\": 40\n}",
                  "type": "text",
                  "contentType": "application/json"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Product (ADMIN, multipart)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "product",
                  "value": "{\n  \"name\": \"Brake Pad Set (Updated)\",\n  \"description\": \"High-performance ceramic pads\",\n  \"price\": 27.99,\n  \"brand\": \"Brembo\",\n  \"categoryId\": {{categoryId}},\n  \"stockQuantity\": 35\n}",
                  "type": "text",
                  "contentType": "application/json"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Product (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "04 - Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] }
          },
          "response": []
        },
        {
          "name": "Add Item to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    var item = Array.isArray(json) ? json[json.length - 1] : json;",
                  "    if (item && item.id) { pm.environment.set('cartItemId', item.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "items", "{{cartItemId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          },
          "response": []
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "items", "{{cartItemId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "05 - Wishlist",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/wishlist", "host": ["{{baseUrl}}"], "path": ["api", "wishlist"] }
          },
          "response": []
        },
        {
          "name": "Add Item to Wishlist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    var item = Array.isArray(json) ? json[json.length - 1] : json;",
                  "    if (item && item.id) { pm.environment.set('wishlistItemId', item.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/wishlist/items", "host": ["{{baseUrl}}"], "path": ["api", "wishlist", "items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}}\n}"
            }
          },
          "response": []
        },
        {
          "name": "Remove Wishlist Item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/wishlist/items/{{wishlistItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wishlist", "items", "{{wishlistItemId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "06 - Orders",
      "item": [
        {
          "name": "Checkout (Create Order)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    if (json.id) { pm.environment.set('orderId', json.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          },
          "response": []
        },
        {
          "name": "Get Order History",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          },
          "response": []
        },
        {
          "name": "Get Order by Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
